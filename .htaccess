# ── Clean URLs (serve about.html at /about, etc.) ────────────────
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Redirect .html URLs to clean URLs (SEO canonical)
  RewriteCond %{THE_REQUEST} \s/([^.]+)\.html[\s?] [NC]
  RewriteRule ^ /%1 [R=301,L]

  # Serve .html file for clean URL if it exists
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.+)$ $1.html [L]
</IfModule>

# ── Custom 404 ───────────────────────────────────────────────────
ErrorDocument 404 /404.html

# ── Compression ──────────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json
</IfModule>

# ── Brotli (if available on Hostinger) ───────────────────────────
<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS text/html text/css text/javascript application/javascript
</IfModule>

# ── Cache lifetimes ───────────────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On
  # WebP / JPEG images — 1 year (fingerprinted by filename)
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png  "access plus 1 year"
  # HTML — revalidate every visit (so updates land instantly)
  ExpiresByType text/html  "access plus 0 seconds"
  # CSS / JS — 1 week
  ExpiresByType text/css                "access plus 1 week"
  ExpiresByType application/javascript  "access plus 1 week"
</IfModule>

# ── Cache-Control headers ─────────────────────────────────────────
<IfModule mod_headers.c>
  <FilesMatch "\.(webp|jpg|jpeg|png|gif|svg|ico|woff2)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(html)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=604800"
  </FilesMatch>
</IfModule>

# ── MIME type for WebP ────────────────────────────────────────────
<IfModule mod_mime.c>
  AddType image/webp .webp
</IfModule>
